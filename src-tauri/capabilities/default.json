{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Default capabilities for Orchestrator Tower",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "store:default",
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "binaries/sidecar",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
